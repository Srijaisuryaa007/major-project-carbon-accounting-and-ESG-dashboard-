  <diagram id="_u14v4SEUS7hKay9k1mi" name="Page-3">
    <mxGraphModel dx="1166" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="BL7ugqGry0V5mcGu9RH5-1" value="&lt;div&gt;&lt;b&gt;1. Input Features (Parameters you collect)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;From your calculator, inputs could be:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Energy consumption (kWh)&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Steam consumption (kg)&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Water usage (m³)&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Chemicals used (kg)&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Production load (kg of fabric/garment)&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Machine efficiency factors (heat transfer, voltage, etc.)&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Country emission factors (kgCO₂/kWh, kgCO₂/kg steam, etc.)&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="110" width="230" height="320" as="geometry" />
        </mxCell>
        <mxCell id="BL7ugqGry0V5mcGu9RH5-2" value="&lt;b&gt;(A) Input Layer:&lt;/b&gt;&lt;div&gt;All parameters are given as features → &lt;code data-end=&quot;1020&quot; data-start=&quot;974&quot;&gt;X = [energy, steam, water, chemicals, load…]&lt;/code&gt;&lt;b&gt;&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="280" width="130" height="140" as="geometry" />
        </mxCell>
        <mxCell id="BL7ugqGry0V5mcGu9RH5-3" value="&lt;b&gt;(B) First Tree (Weak Learner):&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Predicts approximate CO₂ emissions.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Residual error = (Actual – Predicted).&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="280" width="120" height="140" as="geometry" />
        </mxCell>
        <mxCell id="BL7ugqGry0V5mcGu9RH5-4" value="&lt;b&gt;(C) Gradient Boosting Loop:&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Each new decision tree is built to reduce the error of the previous tree.&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Trees are added sequentially, with weights adjusted using gradient descent.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="260" width="120" height="160" as="geometry" />
        </mxCell>
        <mxCell id="BL7ugqGry0V5mcGu9RH5-5" value="&lt;p data-end=&quot;1534&quot; data-start=&quot;1511&quot;&gt;&lt;strong data-end=&quot;1532&quot; data-start=&quot;1511&quot;&gt;(E) Output Layer:&lt;/strong&gt;&lt;/p&gt;&lt;p data-end=&quot;1534&quot; data-start=&quot;1511&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Predicted &lt;/span&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1584&quot; data-start=&quot;1547&quot;&gt;Carbon Emission (kgCO₂e or tCO₂e)&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="350" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="BL7ugqGry0V5mcGu9RH5-6" value="&lt;b&gt;2.Training Data&lt;/b&gt;&lt;div&gt;&lt;b&gt;Historical production &amp;amp; utility consumption data (collected from lab/industry).&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="60" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="BL7ugqGry0V5mcGu9RH5-7" value="&lt;div&gt;&lt;b&gt;Emission factors from government/IPCC datasets.&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Actual measured CO₂ emissions (baseline).&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="180" height="60" as="geometry" />
        </mxCell>
